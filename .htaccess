# Totally not generated by DeepSeek out of my old nginx configs

<IfModule mod_rewrite.c>
	RewriteEngine On

	RewriteCond %{REQUEST_URI} ^/(config|data|incl)/ [NC]
	RewriteRule ^ - [F]

	RewriteCond %{REQUEST_URI} \.json$ [NC]
	RewriteRule ^ - [F]
	
	RewriteCond %{REQUEST_URI} \.txt$ [NC]
	RewriteRule ^ - [F]
	
	
	
	# Music redirects
	
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^sfx/(.+)$ sfx/handler.php?request=$1 [L,QSA]

	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^music/(.+)$ music/handler.php?request=$1 [L,QSA]
	
	RewriteRule ^dashboard/sfxs/(.+)\.(ogg|mp3)$ dashboard/sfxs/handler.php?sfxID=$1 [L,QSA]
	
	RewriteRule ^dashboard/songs/(.+)\.(ogg|mp3)$ dashboard/songs/handler.php?songID=$1 [L,QSA]
	
	
	
	# Page redirects
	
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^dashboard/clan/(.+)$ dashboard/clan/index.php?id=$1 [L,QSA]

	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^dashboard/profile/(.+)$ dashboard/profile/index.php?id=$1 [L,QSA]

	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^dashboard/messenger/(.+)$ dashboard/messenger/index.php?id=$1 [L,QSA]

	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^dashboard/browse/levels/(.+)$ dashboard/browse/levels.php?id=$1 [L,QSA]

	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^dashboard/browse/lists/(.+)$ dashboard/browse/lists.php?id=$1 [L,QSA]

	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^dashboard/browse/mappacks/(.+)$ dashboard/browse/mappacks.php?id=$1 [L,QSA]
	
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^dashboard/browse/gauntlets/(.+)$ dashboard/browse/gauntlets.php?id=$1 [L,QSA]
	
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^dashboard/browse/accounts/(.+)$ dashboard/browse/accounts.php?id=$1 [L,QSA]
	
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^dashboard/browse/songs/(.+)$ dashboard/browse/songs.php?id=$1 [L,QSA]
	
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^dashboard/browse/sfxs/(.+)$ dashboard/browse/sfxs.php?id=$1 [L,QSA]
	
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^dashboard/mod/roles/(.+)$ dashboard/mod/roles.php?id=$1 [L,QSA]
	
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^(.*)$ $1.php [L,QSA]

	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^ - [R=404,L]
</IfModule>